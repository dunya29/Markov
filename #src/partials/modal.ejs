<!--cookie-->
<div class="cookie fixed-block" id="cookie-popup">
    <div class="cookie__inner">
        <button class="btn-cross" onclick="Utils.CookieUtils.hide()"></button>
        <div class="mb-40 cookie__content">
            <h3>Мы используем cookies.</h3>
            <p>Используя сайт, вы&nbsp;соглашаетесь с&nbsp;нашей политикой использования cookie-файлов. Cookies можно отключить в&nbsp;настройках вашего браузера.</p>
        </div>
        <div class="cookie__btns">
            <button class="btn stroke-btn cookie__accept"><span>хорошо</span></button>
        </div>
    </div>
</div>
<!--map-modal-->
<modal class="custom-scroll modal map-modal" id="map-modal">
    <div class="custom-scroll modal__content">
        <button type="button" class="btn-cross modal__close" aria-label="Закрыть модальное окно"></button>
        <div class="mb-24 modal__top">
            <h2 class="h3">Апарт-отель «Марков»</h2>
        </div>
        <div class="map-modal__inner">
            <p>603001, Россия, Нижегородская область<br>г..&nbsp;Нижний Новгород,&nbsp;ул..&nbsp;Ильинская, 1А</p>
            <p><a href="tel:88001001033">8 800 100-10-33</a></p>
            <a
                href="https://yandex.com/maps/47/nizhny-novgorod/house/ilyinskaya_ulitsa_1a/YEoYfw5lSkIAQFtsfX9zeH9jZg==/?ll=43.995378%2C56.329302&source=constructorLink&um=constructor%3A346b5767c6477f6b6884779aabeef53275e5d7556bcb29c57dc4ac516b058219&z=17.11"
                target="_blank" class="btn text-btn"><span>открыть навигатор</span></a>
        </div>
    </div>
</modal>
<!--events-modal-->
<modal class="custom-scroll modal events-modal" id="events-modal">
    <div class="custom-scroll modal__content">
        <button type="button" class="btn-cross modal__close" aria-label="Закрыть модальное окно"></button>
        <div class="mb-24 modal__top">
            <h2 class="h3">Какое мероприятие хотели&nbsp;бы устроить?</h2>
        </div>
        <form class="form" novalidate onsubmit="event.preventDefault();Utils.FormUtils.formReset(this);Utils.ModalUtils.openSuccessMod()">
            <input type="hidden" value data-datepicker-value>
            <div class="mb-24 form__items">
                <div class="ui-control ui-input">
                    <div class="ui-input__inp">
                        <input type="text" placeholder=" " required>
                        <div class="ui-input__placeholder">Ваше имя *</div>
                        <button type="button" class="btn-cross ui-input__reset" aria-label="Очистить поле"></button>
                    </div>
                    <span data-error>Заполните поле</span>
                </div>
                <div class="ui-control ui-input">
                    <div class="ui-input__inp">
                        <input type="email" placeholder=" " required>
                        <div class="ui-input__placeholder">E-mail *</div>
                        <button type="button" class="btn-cross ui-input__reset" aria-label="Очистить поле"></button>
                    </div>
                    <span data-error>Заполните поле</span>
                </div>
                <div class="ui-control ui-input">
                    <div class="ui-input__inp">
                        <input type="tel" placeholder=" " required>
                        <div class="ui-input__placeholder">Телефон *</div>
                        <button type="button" class="btn-cross ui-input__reset" aria-label="Очистить поле"></button>
                    </div>
                    <span data-error>Заполните поле</span>
                </div>
                <div class="ui-control ui-input">
                    <textarea placeholder="Опишите мероприятие"
                        oninput="this.style.height = '';this.style.height = this.scrollHeight + 'px'"></textarea>
                </div>
            </div>
            <div class="h4">Выберите желаемое время звонка:</div>
            <div class="mb-24 form__items">
                <div class="dropdown dropdown--date" aria-expanded="false">
                    <div class="dropdown__header">
                        <svg><use xlink:href="img/svg/sprite.svg#date"></use></svg>
                        <span>29 октября 2025</span>
                        <svg class="dropdown__icon"><use xlink:href="img/svg/sprite.svg#chevron-bot"></use></svg>
                    </div>
                    <div class="dropdown__body">
                        <div class="custom-scroll">
                            <div class="datepicker"></div>
                        </div>
                    </div>
                </div>
                <div class="dropdown radio-select" aria-expanded="false">
                    <div class="dropdown__header">
                        <svg><use xlink:href="img/svg/sprite.svg#time"></use></svg>
                        <span>09:00–10:00</span>
                        <svg class="dropdown__icon"><use xlink:href="img/svg/sprite.svg#chevron-bot"></use></svg>
                    </div>
                    <div class="dropdown__body">
                        <div class="custom-scroll">
                            <div class="dropdown__options">
                                <label>
                                    <input type="radio" name="event-time">
                                    <span>09:00–10:00</span>
                                </label>
                                <label>
                                    <input type="radio" name="event-time">
                                    <span>10:00–11:00</span>
                                </label>
                                <label>
                                    <input type="radio" name="event-time">
                                    <span>11:00–12:00</span>
                                </label>
                                <label>
                                    <input type="radio" name="event-time">
                                    <span>12:00–13:00</span>
                                </label>
                                <label>
                                    <input type="radio" name="event-time">
                                    <span>13:00–14:00</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form__footer">
                <div class="mb-24 ui-control">
                    <label class="ui-checkbox">
                        <input type="checkbox" required>
                        <span>Отправляя данную форму, вы&nbsp;соглашаетесь <a href="#" target="_blank">с&nbsp;Политикой конфиденциальности</a></span>
                    </label>
                    <span data-error>Требуется согласие</span>
                </div>
                <button type="submit" class="btn main-btn" onclick="Utils.FormUtils.formValidate(event, this.closest('form'))">
                    <span>Отправить</span>
                </button>
            </div>
        </form>
    </div>
</modal>
